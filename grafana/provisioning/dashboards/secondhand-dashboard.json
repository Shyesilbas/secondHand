{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Uptime",
      "type": "stat",
      "targets": [{ "expr": "process_uptime_seconds{application=\"$application\", instance=\"$instance\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500000000 }, { "color": "red", "value": 800000000 }] }, "unit": "decbytes" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Heap Used",
      "type": "stat",
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"heap\"})", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "decbytes" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Non-Heap Used",
      "type": "stat",
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"nonheap\"})", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Live Threads",
      "type": "stat",
      "targets": [{ "expr": "jvm_threads_live_threads{application=\"$application\", instance=\"$instance\"}", "refId": "A", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "process_cpu_usage{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Process CPU", "refId": "A" },
        { "expr": "system_cpu_usage{application=\"$application\", instance=\"$instance\"}", "legendFormat": "System CPU", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "System Load Average",
      "type": "timeseries",
      "targets": [
        { "expr": "system_load_average_1m{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Load 1m", "refId": "A" },
        { "expr": "system_cpu_count{application=\"$application\", instance=\"$instance\"}", "legendFormat": "CPU Cores", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } }, "unit": "decbytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"heap\"}", "legendFormat": "{{id}} - Used", "refId": "A" },
        { "expr": "jvm_memory_committed_bytes{application=\"$application\", instance=\"$instance\", area=\"heap\"}", "legendFormat": "{{id}} - Committed", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } }, "unit": "decbytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "JVM Non-Heap Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"nonheap\"}", "legendFormat": "{{id}} - Used", "refId": "A" },
        { "expr": "jvm_memory_committed_bytes{application=\"$application\", instance=\"$instance\", area=\"nonheap\"}", "legendFormat": "{{id}} - Committed", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_live_threads{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Live", "refId": "A" },
        { "expr": "jvm_threads_daemon_threads{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Daemon", "refId": "B" },
        { "expr": "jvm_threads_peak_threads{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Peak", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HikariCP Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Active", "refId": "A" },
        { "expr": "hikaricp_connections_idle{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Idle", "refId": "B" },
        { "expr": "hikaricp_connections_pending{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Pending", "refId": "C" },
        { "expr": "hikaricp_connections{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Total", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "GC Pause Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$application\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "{{action}} - {{cause}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\"}[$__rate_interval])) by (uri, method, status)", "legendFormat": "{{method}} {{uri}} [{{status}}]", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Log Events Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(logback_events_total{application=\"$application\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "{{level}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cache Hit/Miss Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(cache_gets_total{application=\"$application\", instance=\"$instance\", result=\"hit\"}[$__rate_interval])) by (cache)", "legendFormat": "{{cache}} - Hit", "refId": "A" },
        { "expr": "sum(rate(cache_gets_total{application=\"$application\", instance=\"$instance\", result=\"miss\"}[$__rate_interval])) by (cache)", "legendFormat": "{{cache}} - Miss", "refId": "B" }
      ]
    },
    {
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "title": "📡 API İstekleri (Detaylı)", "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "title": "API Ortalama Yanıt Süresi (Latency)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_server_requests_seconds_sum{application=\"$application\", instance=\"$instance\", uri=~\"/api/.*\"}[$__rate_interval]) / rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", uri=~\"/api/.*\"}[$__rate_interval])", "legendFormat": "{{method}} {{uri}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2 }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 45 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "title": "API İstek Hızı (Endpoint Bazlı)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", uri=~\"/api/.*\"}[$__rate_interval])) by (uri, method)", "legendFormat": "{{method}} {{uri}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 25, "lineWidth": 2, "stacking": { "mode": "normal" } }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Durum Kodları (2xx, 4xx, 5xx)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", status=~\"2..\"}[$__rate_interval]))", "legendFormat": "2xx Başarılı", "refId": "A" },
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", status=~\"4..\"}[$__rate_interval]))", "legendFormat": "4xx Client Hata", "refId": "B" },
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", status=~\"5..\"}[$__rate_interval]))", "legendFormat": "5xx Server Hata", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "En Yavaş Endpointler (Max Latency)",
      "type": "timeseries",
      "targets": [
        { "expr": "topk(5, http_server_requests_seconds_max{application=\"$application\", instance=\"$instance\", uri=~\"/api/.*\"})", "legendFormat": "{{method}} {{uri}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1}] }, "unit": "s", "color": { "mode": "thresholds" } }, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 61 },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }], "footer": { "show": false } },
      "title": "API Endpoint Tablosu (Anlık)",
      "type": "table",
      "targets": [
        { "expr": "http_server_requests_seconds_max{application=\"$application\", instance=\"$instance\", uri=~\"/api/.*\"}", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "application": true, "exported_application": true, "instance": true, "job": true, "error": true, "exception": true }, "renameByName": { "method": "Method", "uri": "Endpoint", "status": "Status", "outcome": "Outcome", "Value": "Max Latency (s)" } } }
      ]
    },
    {
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 71 },
      "title": "🗄️ Veritabanı & Redis", "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 72 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean","max"] }, "tooltip": { "mode": "multi" } },
      "title": "Spring Data Repository Süresi",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(spring_data_repository_invocations_seconds_sum{application=\"$application\", instance=\"$instance\"}[$__rate_interval]) / rate(spring_data_repository_invocations_seconds_count{application=\"$application\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "{{repository}}.{{method}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 72 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Redis (Lettuce) Komut Süresi",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(lettuce_command_completion_seconds_sum{application=\"$application\", instance=\"$instance\"}[$__rate_interval]) / rate(lettuce_command_completion_seconds_count{application=\"$application\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "{{command}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 80 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HikariCP Bağlantı Edinme Süresi",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(hikaricp_connections_acquire_seconds_sum{application=\"$application\", instance=\"$instance\"}[$__rate_interval]) / rate(hikaricp_connections_acquire_seconds_count{application=\"$application\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "Acquire Time", "refId": "A" },
        { "expr": "rate(hikaricp_connections_usage_seconds_sum{application=\"$application\", instance=\"$instance\"}[$__rate_interval]) / rate(hikaricp_connections_usage_seconds_count{application=\"$application\", instance=\"$instance\"}[$__rate_interval])", "legendFormat": "Usage Time", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 80 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cache Boyutu (Kayıt Sayısı)",
      "type": "timeseries",
      "targets": [
        { "expr": "cache_size{application=\"$application\", instance=\"$instance\"}", "legendFormat": "{{cache}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 88 },
      "title": "⏰ Zamanlayıcılar (Scheduled Tasks)", "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 89 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean","max","lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Zamanlanmış Görev Süreleri",
      "type": "timeseries",
      "targets": [
        { "expr": "tasks_scheduled_execution_seconds_max{application=\"$application\", instance=\"$instance\"}", "legendFormat": "{{code_function}}", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["spring-boot", "jvm", "secondhand"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      },
      {
        "name": "application",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(application)",
        "refresh": 2,
        "sort": 1,
        "current": { "selected": false, "text": "secondHand", "value": "secondHand" }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(jvm_memory_used_bytes{application=\"$application\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "current": { "selected": false, "text": "host.docker.internal:8080", "value": "host.docker.internal:8080" }
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "SecondHand - Spring Boot Monitoring",
  "uid": "secondhand-monitoring",
  "version": 2
}
