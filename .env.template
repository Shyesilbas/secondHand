# Database Configuration
DB_URL=jdbc:postgresql://postgres:5432/secondhand
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Security / JWT
JWT_SECRET_KEY=your_very_secret_key_here_min_32_chars

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_SCOPE=email,profile
REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
ISSUER_URI=https://accounts.google.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI / Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_MODEL=gemini-3.1-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_FALLBACK_MEMORY_MODEL=gemini-2.0-flash-lite

# Exchange API
EXCHANGE_API_KEY=your_exchange_api_key

# App Configuration
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=3
RATE_LIMIT_PAYMENT=3
RATE_LIMIT_GENERAL=10
RATE_LIMIT_AI=6
RATE_LIMIT_WINDOW=60
